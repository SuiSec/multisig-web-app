{
	"name": "multisig-web-app",
	"type": "module",
	"private": true,
	"workspaces": [
		"sdk",
		"app"
	],
	"scripts": {
		"dev": "cd sdk && bun run build && cd ../app && bun run dev",
		"build": "cd sdk && bun run build && cd ../app && bun run build",
		"build:sdk": "cd sdk && bun run build",
		"build:app": "cd app && bun run build",
		"typecheck": "cd sdk && bun run typecheck && cd ../app && bun run typecheck",
		"lint": "eslint . --ext ts,tsx --max-warnings 0",
		"lint:fix": "eslint . --ext ts,tsx --fix --max-warnings 0",
		"fmt": "prettier --write .",
		"fmt:check": "prettier --check ."
	},
	"devDependencies": {
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@tony.ganchev/eslint-plugin-header": "^3.1.8",
		"@typescript-eslint/eslint-plugin": "^8.62.0",
		"@typescript-eslint/parser": "^8.62.0",
		"eslint": "^9.39.4",
		"globals": "^16.5.0",
		"prettier": "^3.8.4",
		"typescript": "^5.9.3"
	}
}
