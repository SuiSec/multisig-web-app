# Copy to `.env` (or `.env.local`) and fill in. All VITE_* values are PUBLIC —
# they are compiled into the browser bundle, so never put a secret here.

# Base URL of the coordination relay this frontend talks to.
# If unset, the app falls back to https://api.sagat.mystenlabs.com (prod build)
# or http://localhost:3000 (dev). A self-hosted deployment MUST set this to its
# own relay, e.g. https://api.your-domain.app
VITE_API_URL=

# Optional: WalletConnect Cloud project id, to offer WalletConnect as a wallet.
# Leave empty to disable WalletConnect. Get one at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=
